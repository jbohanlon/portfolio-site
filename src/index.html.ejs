<% const { outputAsListItems } = require('./backend-js/helpers.js'); %>
<%= require('./includes/header.html.ejs')({isHomePageNavbar: true, pageTitle: htmlWebpackPlugin.options.pageTitle, pageDescription: htmlWebpackPlugin.options.pageDescription}) %>
<main id="main">
  <section id="home-page-hero" class="d-flex align-items-center">
    <div id="hero-content-wrapper" class="text-white w-100">
      <div id="hero-content" class="text-center mx-auto">
        <h1>
          Hi, I'm Jonathan!
        </h1>
        <p class="h5 py-2">
          I work on cool software projects and have experience with a bunch of different technologies.
        </p>
      </div>
    </div>
  </section>
  <section id="about-me" class="d-flex align-items-center py-5">
    <div id="about-me-wrapper" class="text-center container my-5">
      <h1 class="mb-4">Ready to go</h1>
      <p class="h5 mb-3">
        I love solving problems with code.
        <br />
        Check out my <a href="./projects.html">Projects</a> page to see some things that I've worked on!
      </p>
      <p class="h5">
        I've picked up a lot of skills over the years and I look forward to learning even more.
        Find out about my specialties below!
      </p>
    </div>
  </section>
  <section id="skills" class="pt-5 mb-n5">
    <div class="container my-5">
      <h1 class="text-center mb-5">Skills</h1>
      <div class="row">
        <div class="col-sm-4 text-center mb-5">
          <h2 class="h4"><i class="fas fa-laptop-code"></i> Languages</h2>
          <%= outputAsListItems(['JavaScript', 'NodeJS', 'TypeScript', 'Java', 'Python', 'HTML', 'CSS / SCSS']) %>
        </div>
        <div class="col-sm-4 text-center mb-5">
          <h2 class="h4"><i class="fas fa-dolly-flatbed"></i> Frameworks</h2>
          <%= outputAsListItems(['React', 'Jest', 'Bootstrap', 'Ionic', 'Express', 'NestJS']) %>
        </div>
        <div class="col-sm-4 text-center mb-5">
          <h2 class="h4"><i class="fas fa-cubes"></i> Libraries</h2>
          <%= outputAsListItems(['Redux', 'jQuery', 'webpack', 'Mongoose', 'Capacitor', 'EJS', 'Pug', 'pandas', 'Bokeh']) %>
        </div>
        <div class="col-sm-6 text-center mb-5">
          <h2 class="h4"><i class="fas fa-database"></i> Databases</h2>
          <%= outputAsListItems(['MySQL', 'SQL Server', 'MongoDB', 'Microsoft Access']) %>
        </div>
        <div class="col-sm-6 text-center mb-5">
          <h2 class="h4"><i class="fas fa-rocket"></i> And More!</h2>
          <%= outputAsListItems(['Git', 'Responsive design', 'PWAs (Progressive Web Apps)', 'Adobe Photoshop']) %>
        </div>
      </div>
    </div>
  </section>
</main>
<%= require('./includes/footer.html.ejs')() %>
